 <web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <!-- Login -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>atm.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <!-- Signup -->
    <servlet>
        <servlet-name>SignUpServlet</servlet-name>
        <servlet-class>atm.servlet.SignUpServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SignUpServlet</servlet-name>
        <url-pattern>/SignUpServlet</url-pattern>
    </servlet-mapping>

    <!-- Deposit -->
    <servlet>
        <servlet-name>DepositServlet</servlet-name>
        <servlet-class>atm.servlet.DepositServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DepositServlet</servlet-name>
        <url-pattern>/DepositServlet</url-pattern>
    </servlet-mapping>

    <!-- Withdraw -->
    <servlet>
        <servlet-name>WithdrawServlet</servlet-name>
        <servlet-class>atm.servlet.WithdrawServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>WithdrawServlet</servlet-name>
        <url-pattern>/WithdrawServlet</url-pattern>
    </servlet-mapping>

    <!-- Balance -->
    <servlet>
        <servlet-name>BalanceServlet</servlet-name>
        <servlet-class>atm.servlet.BalanceServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BalanceServlet</servlet-name>
        <url-pattern>/BalanceServlet</url-pattern>
    </servlet-mapping>

    <!-- Transfer -->
    <servlet>
        <servlet-name>TransferServlet</servlet-name>
        <servlet-class>atm.servlet.TransferServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TransferServlet</servlet-name>
        <url-pattern>/TransferServlet</url-pattern>
    </servlet-mapping>

    <!-- Mini Statement -->
    <servlet>
        <servlet-name>MiniStatementServlet</servlet-name>
        <servlet-class>atm.servlet.MiniStatementServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MiniStatementServlet</servlet-name>
        <url-pattern>/MiniStatementServlet</url-pattern>
    </servlet-mapping>

    <!-- Forgot Password -->
    <servlet>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <servlet-class>atm.servlet.ForgotPasswordServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ForgotPasswordServlet</servlet-name>
        <url-pattern>/ForgotPasswordServlet</url-pattern>
    </servlet-mapping>

    <!-- Logout -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>atm.servlet.LogoutServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>

    <!-- Admin Login -->
    <servlet>
        <servlet-name>AdminLoginServlet</servlet-name>
        <servlet-class>atm.servlet.AdminLoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AdminLoginServlet</servlet-name>
        <url-pattern>/AdminLoginServlet</url-pattern>
    </servlet-mapping>

    <!-- Admin Dashboard -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>atm.servlet.AdminDashboardServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/AdminDashboardServlet</url-pattern>
    </servlet-mapping>

    <!-- OTP Send -->
    <servlet>
        <servlet-name>SendOTPServlet</servlet-name>
        <servlet-class>atm.servlet.SendOTPServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>SendOTPServlet</servlet-name>
        <url-pattern>/SendOTPServlet</url-pattern>
    </servlet-mapping>

    <!-- OTP Verify -->
    <servlet>
        <servlet-name>VerifyOTPServlet</servlet-name>
        <servlet-class>atm.servlet.VerifyOTPServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>VerifyOTPServlet</servlet-name>
        <url-pattern>/VerifyOTPServlet</url-pattern>
    </servlet-mapping>

    <!-- Update PIN -->
    <servlet>
        <servlet-name>UpdatePinServlet</servlet-name>
        <servlet-class>atm.servlet.UpdatePinServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>UpdatePinServlet</servlet-name>
        <url-pattern>/UpdatePinServlet</url-pattern>
    </servlet-mapping>

    <servlet>
    <servlet-name>CloseAccountServlet</servlet-name>
    <servlet-class>atm.servlet.CloseAccountServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>CloseAccountServlet</servlet-name>
    <url-pattern>/CloseAccountServlet</url-pattern>
</servlet-mapping>

</web-app>